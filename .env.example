# Database (use DATABASE_URL on Railway, or individual vars locally)
DATABASE_URL=
POSTGRES_DB=testing_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT secrets — generate strong random strings for production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Server
SERVER_ADDR=:8080

# CORS — comma-separated list of allowed frontend origins
# On Railway: set to your frontend Railway URL, e.g. https://ent-ready-frontend.up.railway.app
CORS_ORIGINS=http://localhost:3000

# Telegram bot for OTP notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_username   # без @, например: ent_ready_bot
TELEGRAM_WEBHOOK_URL=https://your-backend.up.railway.app  # URL бэкенда без слеша в конце
